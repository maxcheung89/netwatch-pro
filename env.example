# ════════════════════════════════════════════════════════════════
# NetWatch Pro — Environment Configuration
#
# SETUP:
#   cp .env.example .env
#   nano .env        ← set your password here
#   sudo ./install.sh
#
# install.sh will automatically call `pihole setpassword` after
# startup — no need to set it manually.
#
# Never commit .env to git — it is in .gitignore.
# ════════════════════════════════════════════════════════════════


# ── Passwords ────────────────────────────────────────────────────

# Pi-hole + NetWatch Pro login password.
# Pi-hole v6 NOTE: the WEBPASSWORD env var (v5) is ignored by v6.
# install.sh calls `docker exec pihole pihole setpassword` after startup,
# which is the only reliable method for Pi-hole v6.
# If you ever need to reset it manually:
#   docker exec -it pihole pihole setpassword YOUR_PASSWORD
PIHOLE_PASSWORD=changeme123

# NetWatch Pro login password (leave blank to use PIHOLE_PASSWORD above)
NETWATCH_PASSWORD=

# Pi-hole API token (optional, leave blank — password auth is preferred)
PIHOLE_API_TOKEN=


# ── Network ──────────────────────────────────────────────────────

# Network interface for packet capture.
# Run `ip link show` to find yours.
# Must be ethernet (eth0, ens3, enp2s0, etc.) — WiFi capture does not work.
CAPTURE_INTERFACE=eth0

# LAN subnet in CIDR — used for nmap active scanning.
# "auto" detects from the interface IP address.
NETWORK_RANGE=auto

# Active scan interval in seconds.
SCAN_INTERVAL=60


# ── Pi-hole URLs ─────────────────────────────────────────────────

# Backend-to-backend URL (NetWatch → Pi-hole API).
# Always use 127.0.0.1 — works regardless of Pi-hole's network binding mode.
PIHOLE_URL=http://127.0.0.1:8888

# Browser-accessible URL shown in the Pi-hole tab "Open Admin" link.
# Replace 192.168.1.100 with your server's actual LAN IP.
PIHOLE_PUBLIC_URL=http://192.168.1.100:8888


# ── DNS Setup Note ────────────────────────────────────────────────
#
# Pi-hole binds to port 53. If systemd-resolved is using port 53,
# add these lines to /etc/systemd/resolved.conf:
#
#   [Resolve]
#   DNSStubListener=no
#
# Then run: sudo systemctl restart systemd-resolved
#
# If you prefer to just point /etc/resolv.conf at real DNS servers
# (nameserver 1.1.1.1), that works too — install.sh detects your
# setup and does NOT overwrite an already-working configuration.


# ── Cloudflare Tunnel ─────────────────────────────────────────────

# Set to 1 if accessing NetWatch via a Cloudflare Tunnel (HTTPS).
# Set to 0 for direct LAN access (HTTP).
# With 1: session cookies use Secure flag (requires HTTPS).
# With 0: cookies work over plain HTTP (LAN access).
BEHIND_CLOUDFLARE=0


# ── Timezone ─────────────────────────────────────────────────────

TZ=America/Chicago


# ── Suricata IDS (optional) ───────────────────────────────────────

# Path to Suricata's EVE JSON log on the host.
SURICATA_EVE_LOG=/var/log/suricata/eve.json
