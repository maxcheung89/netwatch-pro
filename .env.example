# ════════════════════════════════════════════════════════════════
# NetWatch Pro — Environment Configuration
#
# SETUP:
#   cp .env.example .env
#   nano .env        ← set your passwords here
#   sudo ./install.sh
#
# Never commit .env to git — it contains passwords.
# ════════════════════════════════════════════════════════════════


# ── Passwords ────────────────────────────────────────────────────

# Pi-hole web UI password (also used as NetWatch login if NETWATCH_PASSWORD is blank)
PIHOLE_PASSWORD=changeme123

# NetWatch Pro login password
# Leave blank to inherit PIHOLE_PASSWORD above
NETWATCH_PASSWORD=

# Pi-hole API token (optional — password auth preferred for Pi-hole v6)
PIHOLE_API_TOKEN=


# ── Network ──────────────────────────────────────────────────────

# Network interface to capture traffic on
# Run `ip link show` to find yours — usually eth0 or ens3
CAPTURE_INTERFACE=eth0

# Your LAN subnet in CIDR notation — used for active nmap scanning
# Set to "auto" to detect automatically from the interface IP
NETWORK_RANGE=auto

# Active scan interval in seconds (how often to run nmap + arp-scan)
SCAN_INTERVAL=60


# ── Pi-hole URLs ─────────────────────────────────────────────────

# Internal URL for NetWatch → Pi-hole API calls (backend-to-backend)
# Use 127.0.0.1 so it always goes through the host's loopback
PIHOLE_URL=http://127.0.0.1:8888

# Browser-accessible URL for the Pi-hole admin link in the dashboard
# Use your server's LAN IP
PIHOLE_PUBLIC_URL=http://192.168.1.100:8888


# ── Cloudflare Tunnel ─────────────────────────────────────────────

# Set to 1 if you're exposing NetWatch via a Cloudflare Tunnel
# This enables secure (HTTPS-only) session cookies
# Set to 0 for LAN-only access
BEHIND_CLOUDFLARE=0


# ── Timezone ─────────────────────────────────────────────────────

# Timezone for timestamps — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Chicago


# ── Suricata IDS (optional) ───────────────────────────────────────

# Path to Suricata's EVE JSON log (mounted read-only into the container)
# Leave as-is if Suricata is installed on the host
SURICATA_EVE_LOG=/var/log/suricata/eve.json
